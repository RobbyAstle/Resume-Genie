# Optional: override the local storage path (defaults to ./data)
DATA_DIR=./data

# Optional: set API keys here instead of (or in addition to) the Settings UI.
# Keys entered in the Settings UI take precedence over these.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: path to a Chromium/Chrome executable for PDF generation.
# Set automatically in standalone ZIP builds. For local dev, leave unset
# to let puppeteer-core auto-detect your installed Chrome.
# PUPPETEER_EXECUTABLE_PATH=/path/to/chrome
